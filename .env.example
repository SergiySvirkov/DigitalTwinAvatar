# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
GPT_MODEL=gpt-4o-mini
TTS_MODEL=tts-1-hd

# ChromaDB Configuration
CHROMA_DB_PATH=./data/chromadb
CHROMA_COLLECTION_NAME=conversation_memory

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8081
FRONTEND_PORT=8080

# WebRTC Configuration
RTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]}]

# Persona Configuration
DEFAULT_PERSONA=friendly_assistant
PERSONAS_DIR=./shared/personas

# Animation Configuration
ANIMATION_MODEL_PATH=./shared/models/liveportrait
TTS_MODEL_PATH=./shared/models/tts

# Vision Configuration
VISION_FRAME_INTERVAL=5
VISION_ENABLED=true

# Audio Configuration
AUDIO_SAMPLE_RATE=24000
AUDIO_CHANNELS=1
